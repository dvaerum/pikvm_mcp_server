# PiKVM MCP Server Configuration

# Required: PiKVM host URL
PIKVM_HOST=https://<your-pikvm-ip>

# Required: PiKVM password
PIKVM_PASSWORD=your_password

# Optional: PiKVM username (default: admin)
PIKVM_USERNAME=admin

# Optional: Verify SSL certificates (default: false for self-signed certs)
PIKVM_VERIFY_SSL=false

# Optional: Default keyboard layout (default: en-us)
PIKVM_DEFAULT_KEYMAP=en-us

# Optional: Auto-calibration settings
# Number of sampling rounds for auto-calibration (default: 5)
PIKVM_CALIBRATION_ROUNDS=5
# Number of verification rounds after computing calibration (default: 5)
PIKVM_CALIBRATION_VERIFY_ROUNDS=5
# Delay in ms after each mouse move during calibration (default: 300, increase for slow connections)
PIKVM_CALIBRATION_MOVE_DELAY=300

# Click proximity gate: skip a click when the verified cursor is more than
# this many px from target (prevents wrong-element clicks). Default 35 on iPad,
# off on desktop. Set to a number to tune, or "off"/0 to disable.
#PIKVM_CLICK_MAX_RESIDUAL_PX=35
